{
    "name": "IA na Pratica - FINAL",
    "image": "tiryoh/ros2-desktop-vnc:humble",
    "remoteUser": "root",
    "overrideCommand": false,
    "containerEnv": {
        "DISPLAY": ":1",
        "TURTLEBOT3_MODEL": "burger"
        
    },

    "forwardPorts": [80], // Mudamos de 6080 para 80!
    "portsAttributes": {
        "80": {
            "label": "Interface Visual (Acesse via Navegador)",
            "onAutoForward": "openPreview"
        }
    },
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y ros-humble-turtlebot3-simulations ros-humble-turtlebot3-gazebo"
}